{
  "installCommand": "cd frontend && yarn install --frozen-lockfile",
  "buildCommand": "cd frontend && CI=false yarn build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.py": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
